# Production frontend settings
ENVIRONMENT=testing

# Backend API base path exposed by nginx.
VITE_API_URL=/api/v1

# Client-side encryption key used by localStorage helpers.
VITE_SECRET_KEY=app_secret

# Harvey backend path exposed by nginx.
VITE_HARVEY_URL=http://localhost:8086

# Host used when Harvey needs to link back to Sphere assets.
VITE_SPHERE_HOST=sphere.score.us.es