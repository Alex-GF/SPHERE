# Example frontend settings
ENVIRONMENT=development

# Backend API base path exposed by Vite proxy or nginx.
VITE_API_URL=/api/v1

# Client-side encryption key used by localStorage helpers.
VITE_SECRET_KEY=secret

# Optional Harvey endpoint for local development.
VITE_HARVEY_URL=http://localhost:8086

# Required when Harvey needs to build links back to Sphere.
VITE_SPHERE_HOST=sphere.score.us.es