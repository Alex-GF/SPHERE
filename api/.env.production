# Global settings
ENVIRONMENT=production
DATABASE_TECHNOLOGY=mongoDB
SERVER_PORT=8080
BASE_URL_PATH=

# MongoDB connection used inside docker compose
MONGO_PROTOCOL=mongodb
MONGO_HOST=mongodb
MONGO_PORT=27017
DATABASE_NAME=sphere_db
DATABASE_USERNAME=testUser
DATABASE_PASSWORD=testUser

# Credentials consumed by api/init-mongo.sh
MONGO_INITDB_DATABASE=sphere_db
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=4dm1n

# Public URLs and static folders
SERVER_HOST=https://sphere.score.us.es
SERVER_STATICS_FOLDER=public/
AVATARS_FOLDER=public/avatars
COLLECTIONS_FOLDER=public/static/collections

# Redis cache
REDIS_URL=redis://redis:6379

# Seeded production credentials
ADMIN_PASSWORD=4dm1n
USER_PASSWORD=test